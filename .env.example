# ─────────────────────────────────────────────────────────────
# Tracking / Cookie Consent (Google Consent Mode v2)
# Toate sunt NEXT_PUBLIC_* (folosite în client). Dacă un ID lipsește,
# loaderul respectiv NU se randează (tool-ul e efectiv dezactivat).
# ─────────────────────────────────────────────────────────────

# Google Analytics 4 — ex: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel — ex: 1234567890123456
NEXT_PUBLIC_META_PIXEL_ID=META_PIXEL_ID
